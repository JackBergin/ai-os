# Copy to .env and adjust as needed:
#   cp .env.example .env

# Host-published ports
OLLAMA_PORT=11434
OPEN_WEBUI_PORT=8080
SEARXNG_HOST_PORT=8081

# Odysseus (from included upstream compose)
APP_BIND=0.0.0.0
APP_PORT=7000
APP_DATA_DIR=./odysseus-data
APP_LOGS_DIR=./odysseus-logs

# Point Odysseus at the compose `ollama` service (same Docker network).
OLLAMA_BASE_URL=http://ollama:11434
LLM_HOST=ollama

AUTH_ENABLED=true
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=changeme

# Match your host user for bind-mount ownership (Linux). macOS often keeps 1000.
# PUID=$(id -u)
# PGID=$(id -g)
PUID=1000
PGID=1000

WEBUI_AUTH=False
